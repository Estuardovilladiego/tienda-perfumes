# Copia este archivo a .env y ajusta tus credenciales.
# Antes de Vercel: npm run check:prod

# ── Base de datos ──────────────────────────────────────────────
# Local (XAMPP):
# DATABASE_URL="mysql://root:@localhost:3306/essenza_perfumes"
# Producción (Railway / PlanetScale):
# DATABASE_URL="mysql://user:pass@host.railway.app:3306/railway"

DATABASE_URL="mysql://root:tu_password@localhost:3306/essenza_perfumes"
# Solo para npm run sync:products (copiar productos de XAMPP → Railway)
# LOCAL_DATABASE_URL="mysql://root:@localhost:3306/essenza_perfumes"

# USE_STATIC_PRODUCTS=true   # solo demo sin MySQL

# ── Admin (/admin/login) ─────────────────────────────────────
ADMIN_EMAIL=essenzaperfumeria312@gmail.com
ADMIN_PASSWORD=cambia_esta_contraseña_fuerte
# Genera uno: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SESSION_SECRET=

# ── URL pública (SEO, sitemap, correos) ──────────────────────
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Vercel (cámbiala tras el primer deploy):
# NEXT_PUBLIC_SITE_URL=https://tu-proyecto.vercel.app

# ── Imágenes admin (obligatorio en Vercel) ───────────────────
# cloudinary.com → Dashboard → Account Details (Cloud name, API Key, API Secret)
# Upload preset: essenza_unsigned — preferible modo "Unsigned"
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=essenza_unsigned
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (Gmail + contraseña de aplicación) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=essenzaperfumeria312@gmail.com
SMTP_PASS=
SMTP_FROM=Essenza Perfumería <essenzaperfumeria312@gmail.com>
SMTP_REPLY_TO=essenzaperfumeria312@gmail.com

